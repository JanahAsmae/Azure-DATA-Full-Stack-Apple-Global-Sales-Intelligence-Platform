                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT
    CAST(sale_id AS NVARCHAR(20))                     AS Sale_ID,
    TRY_CAST(sale_date AS DATE)                       AS Sale_Date,
    TRY_CAST(year AS INT)                             AS Year,
    CAST(quarter AS NVARCHAR(5))                      AS Quarter,
    CAST(month AS NVARCHAR(20))                       AS Month,
    CAST(country AS NVARCHAR(100))                    AS Country,
    CAST(region AS NVARCHAR(100))                     AS Region,
    CAST(city AS NVARCHAR(100))                       AS City,
    CAST(product_name AS NVARCHAR(200))               AS Product_Name,
    CAST(category AS NVARCHAR(100))                   AS Category,
    CAST(storage AS NVARCHAR(50))                     AS Storage,
    CAST(color AS NVARCHAR(50))                       AS Color,
    TRY_CAST(unit_price_usd AS DECIMAL(10,2))         AS Unit_Price_USD,
    TRY_CAST(discount_pct AS DECIMAL(5,2))            AS Discount_Pct,
    TRY_CAST(units_sold AS INT)                       AS Units_Sold,
    TRY_CAST(discounted_price_usd AS DECIMAL(10,2))   AS Discounted_Price_USD,
    TRY_CAST(revenue_usd AS DECIMAL(15,2))            AS Revenue_USD,
    CAST(currency AS NVARCHAR(10))                    AS Currency,
    TRY_CAST(fx_rate_to_usd AS DECIMAL(10,4))         AS FX_Rate_To_USD,
    TRY_CAST(revenue_local_currency AS DECIMAL(20,2)) AS Revenue_Local_Currency,
    CAST(sales_channel AS NVARCHAR(100))              AS Sales_Channel,
    CAST(payment_method AS NVARCHAR(50))              AS Payment_Method,
    CAST(customer_segment AS NVARCHAR(50))            AS Customer_Segment,
    CAST(customer_age_group AS NVARCHAR(20))          AS Customer_Age_Group,
    CAST(previous_device_os AS NVARCHAR(50))          AS Previous_Device_OS,
    TRY_CAST(customer_rating AS DECIMAL(3,1))         AS Customer_Rating,
    CAST(return_status AS NVARCHAR(20))               AS Return_Status
FROM dbo.apple_global_sales_dataset</property>
